{
  "_comment": "Copy this file to your project root as .ai-slop-cleaner.json and adjust as needed.",

  "scope": "diff",

  "dryRun": false,

  "targetExtensions": [".js", ".ts", ".jsx", ".tsx", ".mjs", ".cjs"],

  "languages": {
    "javascript": {
      "extensions": [".js", ".mjs", ".cjs"],
      "commentSyntax": "//",
      "blockCommentSyntax": ["/*", "*/"]
    },
    "typescript": {
      "extensions": [".ts", ".tsx"],
      "commentSyntax": "//",
      "blockCommentSyntax": ["/*", "*/"]
    },
    "python": {
      "extensions": [".py"],
      "commentSyntax": "#",
      "blockCommentSyntax": ["\"\"\"", "\"\"\""]
    },
    "go": {
      "extensions": [".go"],
      "commentSyntax": "//",
      "blockCommentSyntax": ["/*", "*/"]
    },
    "php": {
      "extensions": [".php"],
      "commentSyntax": "//",
      "blockCommentSyntax": ["/*", "*/"]
    }
  },

  "rules": {
    "removeRedundantComments": true,
    "removeTemplateComments": true,
    "removeAIMetaPhrases": true,
    "removeDebugLabels": true,
    "removeInflatedJSDoc": true,
    "removeEmojisInComments": true,
    "removeEmojisInLogs": true,
    "removeEmojisInErrorMessages": true,
    "cleanProse": false
  },

  "preserve": {
    "todoFixme": true,
    "linterDirectives": true,
    "licenseHeaders": true,
    "commentedOutCode": true
  },

  "metrics": {
    "enabled": true,
    "outputFile": ".ai-slop-metrics.json",
    "trackPerCommit": true
  },

  "perDirectory": {
    "docs/": {
      "removeRedundantComments": false,
      "removeTemplateComments": false,
      "removeEmojisInComments": false,
      "cleanProse": true
    },
    "src/": {
      "removeRedundantComments": true,
      "removeEmojisInComments": true
    },
    "tests/": {
      "removeDebugLabels": false
    },
    "__tests__/": {
      "removeDebugLabels": false
    }
  },

  "ignoreFiles": [
    "dist/**",
    "build/**",
    "node_modules/**",
    "*.min.js",
    "*.generated.ts",
    "*.d.ts"
  ],

  "metrics": {
    "enabled": false,
    "_comment": "Set enabled: true to write cleanup history to .ai-slop-metrics.json. Not yet implemented."
  }
}
